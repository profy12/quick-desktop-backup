# Backblaze B2 credentials (via S3-compatible API)
# Create an application key at: https://secure.backblaze.com/app_keys.htm
AWS_ACCESS_KEY_ID=your-b2-key-id
AWS_SECRET_ACCESS_KEY=your-b2-application-key

# Restic repository — format: s3:https://s3.REGION.backblazeb2.com/BUCKET-NAME
# Find your region in the B2 bucket settings (e.g. us-west-004)
RESTIC_REPOSITORY=s3:https://s3.us-west-004.backblazeb2.com/your-bucket-name

# Restic encryption password — keep this safe, losing it = losing your backups
RESTIC_PASSWORD=your-strong-password

# Directories to back up — space-separated absolute paths
BACKUP_SOURCES=/home/youruser/Documents /home/youruser/Images
